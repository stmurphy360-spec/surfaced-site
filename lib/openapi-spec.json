    },
    "/files/{run_id}/print": {
      "get": {
        "summary": "Print Report",
        "description": "Serve report HTML with auto-print script injected \u2014 triggers browser print dialog.\n\nIntended use: open this URL in a new tab to auto-trigger browser PDF export.\nThe print dialog opens immediately, letting the user save as PDF without any\nserver-side PDF library.",
        "operationId": "print_report_files__run_id__print_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "run_id",
