  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Service health check \u2014 NOT auth protected (Railway healthcheck hits this).",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/files/{run_id}/report.html": {
      "get": {
        "summary": "Download Report",
        "description": "Serve HTML report file for a completed run \u2014 DWNLD-01.",
        "operationId": "download_report_files__run_id__report_html_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
