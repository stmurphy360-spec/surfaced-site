    "/runs/{run_id}/regenerate-report": {
      "post": {
        "summary": "Regenerate Report",
        "description": "Re-render report.html (and CSVs) for an existing run using the current reporter template.",
        "operationId": "regenerate_report_runs__run_id__regenerate_report_post",
        "security": [
